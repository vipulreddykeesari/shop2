{
  "name": "smart-chicken-shop",
  "version": "1.0.0",
  "description": "Smart Chicken Shop - Digital platform for fresh chicken ordering & delivery",
  "private": true,
  "workspaces": [
    "apps/web",
    "services/*",
    "mcp-server"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:mcp": "cd mcp-server && npm run dev",
    "dev:auth": "cd services/auth-service && npm run dev",
    "dev:product": "cd services/product-service && npm run dev",
    "dev:order": "cd services/order-service && npm run dev",
    "dev:delivery": "cd services/delivery-service && npm run dev",
    "dev:payment": "cd services/payment-service && npm run dev",
    "dev:all": "concurrently \"npm:dev:*\"",
    "install:all": "npm install && cd apps/web && npm install && cd ../../mcp-server && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
