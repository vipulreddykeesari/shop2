{
  "expo": {
    "name": "Rahman Chicken Center",
    "slug": "rahman-chicken-center",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "rahmanchicken",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#e63946"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rahmanchicken.center"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e63946"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rahmanchicken.center"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
